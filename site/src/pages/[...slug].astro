---
import Base from '../layouts/Base.astro';
import { getAllPages, renderNote } from '../lib/vault.js';

export function getStaticPaths() {
  return getAllPages();
}

const { dir, file } = Astro.props;
const { title, html } = renderNote(dir, file);
---
<Base title={title} breadcrumb={title}>
  <article set:html={html} />
</Base>
