---
import Base from '../layouts/Base.astro';
import { listNotes, renderNote } from '../lib/vault.js';

const guides = listNotes('guides');
const refs = listNotes('reference');
const { html: welcomeHtml } = renderNote('', 'Welcome.md');
---
<Base>
  <div style="display: inline-block; padding: 0.2rem 0.8rem; background: var(--surface); border: 1px solid var(--border); border-radius: 20px; font-size: 0.8rem; color: var(--muted); margin-bottom: 1rem;">
    Codex v0.2.0 Beta
  </div>

  <h1 style="font-size: 2.2rem; margin-bottom: 0.3rem;">Codex</h1>
  <p style="color: var(--muted); font-size: 1.05rem; margin-bottom: 2.5rem; line-height: 1.6;">
    Local-first knowledge management, built in Rust.<br/>
    Markdown is the source of truth.
  </p>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem;">
    <div>
      <h3 style="color: var(--muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; border: none; padding: 0;">Guides</h3>
      {guides.map(g => (
        <a href={`/${g.slug}/`} style="display: block; padding: 0.3rem 0; color: var(--fg); font-size: 0.95rem;">{g.title}</a>
      ))}
    </div>
    <div>
      <h3 style="color: var(--muted); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; border: none; padding: 0;">Reference</h3>
      {refs.map(r => (
        <a href={`/${r.slug}/`} style="display: block; padding: 0.3rem 0; color: var(--fg); font-size: 0.95rem;">{r.title}</a>
      ))}
    </div>
  </div>

  <hr/>

  <article set:html={welcomeHtml} />
</Base>
