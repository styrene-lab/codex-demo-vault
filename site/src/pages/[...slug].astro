---
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const vaultRoot = path.resolve('../');
  const pages = [];

  for (const dir of ['guides', 'reference']) {
    const dirPath = path.join(vaultRoot, dir);
    if (!fs.existsSync(dirPath)) continue;
    for (const file of fs.readdirSync(dirPath)) {
      if (!file.endsWith('.md')) continue;
      const slug = file.replace('.md', '').toLowerCase().replace(/\s+/g, '-');
      pages.push({ params: { slug }, props: { dir, file } });
    }
  }

  // Welcome page
  pages.push({ params: { slug: 'welcome' }, props: { dir: '', file: 'Welcome.md' } });

  return pages;
}

const { dir, file } = Astro.props;
const vaultRoot = path.resolve('../');
const filePath = dir ? path.join(vaultRoot, dir, file) : path.join(vaultRoot, file);
const raw = fs.readFileSync(filePath, 'utf-8');

// Strip frontmatter
const body = raw.replace(/^\+\+\+[\s\S]*?\+\+\+\s*/, '');
const titleMatch = raw.match(/title\s*=\s*"([^"]+)"/);
const title = titleMatch ? titleMatch[1] : file.replace('.md', '');

// Simple markdown rendering
function md(text) {
  let html = text
    .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[\[([^\]]+)\]\]/g, (_, t) => {
      const slug = t.toLowerCase().replace(/\s+/g, '-');
      return `<a href="/${slug}">${t}</a>`;
    })
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/^- (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>\n?)+/gs, '<ul>$&</ul>');

  // Tables
  html = html.replace(/(\|.+\|[\r\n]+\|[-| :]+\|[\r\n]+((\|.+\|[\r\n]*)+))/g, (table) => {
    const rows = table.trim().split('\n').filter(r => !r.match(/^\|[-| :]+\|$/));
    const [header, ...body] = rows;
    const ths = header.split('|').filter(c => c.trim()).map(c => `<th>${c.trim()}</th>`).join('');
    const trs = body.map(r => {
      const tds = r.split('|').filter(c => c.trim()).map(c => `<td>${c.trim()}</td>`).join('');
      return `<tr>${tds}</tr>`;
    }).join('');
    return `<table><thead><tr>${ths}</tr></thead><tbody>${trs}</tbody></table>`;
  });

  // Fenced code blocks
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code class="language-$1">$2</code></pre>');

  // Paragraphs
  html = html.replace(/\n\n/g, '</p><p>');

  return html;
}
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Codex</title>
    <style>
      :root {
        --bg: #06080e;
        --surface: #0c1018;
        --border: #1a2233;
        --fg: #c4d8e4;
        --muted: #6a7a8a;
        --accent: #6ecad8;
        --font: 'Inter', system-ui, -apple-system, sans-serif;
        --mono: 'JetBrains Mono', 'SF Mono', monospace;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: var(--font); background: var(--bg); color: var(--fg); line-height: 1.7; }
      .shell { max-width: 860px; margin: 0 auto; padding: 3rem 2rem; }
      .breadcrumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.5rem; }
      .breadcrumb a { color: var(--muted); }
      .breadcrumb a:hover { color: var(--accent); }
      h1 { font-size: 2rem; margin: 0 0 1rem; color: #fff; }
      h2 { font-size: 1.3rem; margin: 2rem 0 0.5rem; color: #fff; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      h3 { font-size: 1.1rem; margin: 1.5rem 0 0.3rem; color: var(--accent); }
      h4 { font-size: 1rem; margin: 1rem 0 0.3rem; color: var(--fg); }
      p { margin: 0.5rem 0; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      code { background: var(--surface); padding: 0.15rem 0.4rem; border-radius: 4px; font-family: var(--mono); font-size: 0.9em; }
      pre { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1rem; overflow-x: auto; margin: 1rem 0; }
      pre code { background: none; padding: 0; }
      ul { padding-left: 1.5rem; margin: 0.5rem 0; }
      li { margin: 0.2rem 0; }
      table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
      th, td { text-align: left; padding: 0.5rem 0.75rem; border: 1px solid var(--border); }
      th { background: var(--surface); color: var(--accent); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; }
      footer { margin-top: 4rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.8rem; }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="breadcrumb"><a href="/">Codex</a> / {title}</div>
      <div set:html={md(body)} />
      <footer>
        <p><a href="/">Back to index</a> · Generated from <a href="https://github.com/styrene-lab/codex-demo-vault">codex-demo-vault</a></p>
      </footer>
    </div>
  </body>
</html>
