---
const { title, breadcrumb } = Astro.props;
const pageTitle = title ? `${title} — Codex` : 'Codex — Knowledge Kernel';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

      :root {
        --bg:       #06080e;
        --surface:  #0c1018;
        --surface2: #111822;
        --border:   #1a2233;
        --fg:       #c4d8e4;
        --fg-bright:#e8f0f6;
        --muted:    #6a7a8a;
        --accent:   #6ecad8;
        --accent2:  #4a9ba8;
        --font:     'Inter', system-ui, -apple-system, sans-serif;
        --mono:     'JetBrains Mono', 'SF Mono', 'Cascadia Code', monospace;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.75;
        font-size: 15px;
        -webkit-font-smoothing: antialiased;
      }

      .shell {
        max-width: 780px;
        margin: 0 auto;
        padding: 2.5rem 2rem 4rem;
      }

      /* ── Typography ─────────────────────────────────── */

      h1 {
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--fg-bright);
        margin: 0 0 1.2rem;
        letter-spacing: -0.02em;
        line-height: 1.3;
      }

      h2 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--fg-bright);
        margin: 2.5rem 0 0.6rem;
        padding-bottom: 0.35rem;
        border-bottom: 1px solid var(--border);
        letter-spacing: -0.01em;
      }

      h3 {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--accent);
        margin: 1.8rem 0 0.4rem;
      }

      h4 {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--fg);
        margin: 1.4rem 0 0.3rem;
      }

      p {
        margin: 0.6rem 0;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s;
      }
      a:hover {
        color: var(--fg-bright);
        text-decoration: underline;
      }

      strong { color: var(--fg-bright); }

      /* ── Code ────────────────────────────────────────── */

      code {
        background: var(--surface2);
        padding: 0.15rem 0.45rem;
        border-radius: 4px;
        font-family: var(--mono);
        font-size: 0.88em;
        color: var(--accent);
      }

      pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1rem 1.2rem;
        overflow-x: auto;
        margin: 1rem 0;
        line-height: 1.55;
      }

      pre code {
        background: none;
        padding: 0;
        color: var(--fg);
        font-size: 0.85em;
      }

      /* ── Lists ───────────────────────────────────────── */

      ul, ol {
        padding-left: 1.6rem;
        margin: 0.5rem 0;
      }

      li {
        margin: 0.3rem 0;
      }

      li > ul, li > ol {
        margin: 0.15rem 0;
      }

      /* ── Tables ──────────────────────────────────────── */

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.2rem 0;
        font-size: 0.92em;
      }

      th, td {
        text-align: left;
        padding: 0.55rem 0.85rem;
        border: 1px solid var(--border);
      }

      th {
        background: var(--surface);
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      td { background: var(--surface); }
      tr:hover td { background: var(--surface2); }

      /* ── Blockquote ──────────────────────────────────── */

      blockquote {
        border-left: 3px solid var(--accent2);
        padding: 0.4rem 1rem;
        margin: 1rem 0;
        color: var(--muted);
        background: var(--surface);
        border-radius: 0 6px 6px 0;
      }

      /* ── HR ──────────────────────────────────────────── */

      hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
      }

      /* ── Navigation ──────────────────────────────────── */

      .breadcrumb {
        font-size: 0.85rem;
        color: var(--muted);
        margin-bottom: 1.8rem;
      }
      .breadcrumb a { color: var(--muted); }
      .breadcrumb a:hover { color: var(--accent); }
      .breadcrumb .sep { margin: 0 0.4rem; opacity: 0.4; }

      footer {
        margin-top: 4rem;
        padding-top: 1.2rem;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.8rem;
        line-height: 1.6;
      }

      /* ── Responsiveness ──────────────────────────────── */

      @media (max-width: 640px) {
        .shell { padding: 1.5rem 1rem 3rem; }
        h1 { font-size: 1.5rem; }
        h2 { font-size: 1.1rem; }
        table { font-size: 0.82em; }
        pre { padding: 0.8rem; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      {breadcrumb && (
        <div class="breadcrumb">
          <a href="/">Codex</a><span class="sep">/</span>{breadcrumb}
        </div>
      )}
      <slot />
      <footer>
        <p>Generated from the <a href="https://github.com/styrene-lab/codex-demo-vault">codex-demo-vault</a> — a live Codex vault you can clone and open in the app.</p>
      </footer>
    </div>
  </body>
</html>
